@page
@model IndexModel
@{
    ViewData["Title"] = "Calculator";
}

<div class="calculator-wrapper">
    <div class="calculator">
        <div class="display-container">
            <div class="display-operation" id="operationDisplay"></div>
            <div class="display-main" id="display">0</div>
        </div>

        <div class="buttons-container">
            <!-- Row 1 -->
            <button type="button" class="btn btn-function btn-clear" onclick="clearDisplay()">C</button>
            <button type="button" class="btn btn-function" onclick="toggleSign()">+/-</button>
            <button type="button" class="btn btn-function" onclick="appendNumber('.')">.</button>
            <button type="button" class="btn btn-operation" onclick="setOperation('divide')">÷</button>

            <!-- Row 2 -->
            <button type="button" class="btn btn-number" onclick="appendNumber('7')">7</button>
            <button type="button" class="btn btn-number" onclick="appendNumber('8')">8</button>
            <button type="button" class="btn btn-number" onclick="appendNumber('9')">9</button>
            <button type="button" class="btn btn-operation" onclick="setOperation('multiply')">×</button>

            <!-- Row 3 -->
            <button type="button" class="btn btn-number" onclick="appendNumber('4')">4</button>
            <button type="button" class="btn btn-number" onclick="appendNumber('5')">5</button>
            <button type="button" class="btn btn-number" onclick="appendNumber('6')">6</button>
            <button type="button" class="btn btn-operation" onclick="setOperation('subtract')">−</button>

            <!-- Row 4 -->
            <button type="button" class="btn btn-number" onclick="appendNumber('1')">1</button>
            <button type="button" class="btn btn-number" onclick="appendNumber('2')">2</button>
            <button type="button" class="btn btn-number" onclick="appendNumber('3')">3</button>
            <button type="button" class="btn btn-operation" onclick="setOperation('add')">+</button>

            <!-- Row 5 -->
            <button type="button" class="btn btn-number btn-zero" onclick="appendNumber('0')">0</button>
            <button type="button" class="btn btn-equals" onclick="calculate()">=</button>
        </div>
    </div>
</div>

<script>
let display = document.getElementById('display');
let operationDisplay = document.getElementById('operationDisplay');
let currentNumber = '0';
let previousNumber = '';
let operation = '';
let shouldResetDisplay = false;

const operationSymbols = {
    'add': '+',
    'subtract': '−',
    'multiply': '×',
    'divide': '÷'
};

function updateDisplay() {
    display.textContent = currentNumber.length > 0 ? currentNumber : '0';
}

function updateOperationDisplay() {
    if (operation) {
        operationDisplay.textContent = `${previousNumber} ${operationSymbols[operation]}`;
    } else {
        operationDisplay.textContent = '';
    }
}

function appendNumber(num) {
    if (shouldResetDisplay) {
        currentNumber = num === '.' ? '0.' : num;
        shouldResetDisplay = false;
    } else {
        if (num === '.') {
            if (!currentNumber.includes('.')) {
                currentNumber += '.';
            }
        } else {
            if (currentNumber === '0') {
                currentNumber = num;
            } else {
                currentNumber += num;
            }
        }
    }
    updateDisplay();
}

function setOperation(op) {
    if (operation && !shouldResetDisplay) {
        calculate();
    }
    previousNumber = currentNumber;
    operation = op;
    shouldResetDisplay = true;
    updateOperationDisplay();
}

function calculate() {
    if (!operation || shouldResetDisplay) return;

    const num1 = parseFloat(previousNumber);
    const num2 = parseFloat(currentNumber);
    let result;

    try {
        switch (operation) {
            case 'add':
                result = num1 + num2;
                break;
            case 'subtract':
                result = num1 - num2;
                break;
            case 'multiply':
                result = num1 * num2;
                break;
            case 'divide':
                if (num2 === 0) {
                    currentNumber = 'Error';
                    operation = '';
                    previousNumber = '';
                    shouldResetDisplay = true;
                    updateDisplay();
                    updateOperationDisplay();
                    return;
                }
                result = num1 / num2;
                break;
            default:
                currentNumber = 'Error';
                updateDisplay();
                return;
        }

        // Round to avoid floating point precision issues
        result = Math.round(result * 1e10) / 1e10;

        currentNumber = result.toString();
        operation = '';
        previousNumber = '';
        shouldResetDisplay = true;
        updateDisplay();
        updateOperationDisplay();
    } catch (error) {
        currentNumber = 'Error';
        operation = '';
        previousNumber = '';
        shouldResetDisplay = true;
        updateDisplay();
        updateOperationDisplay();
    }
}

function clearDisplay() {
    currentNumber = '0';
    previousNumber = '';
    operation = '';
    shouldResetDisplay = false;
    updateDisplay();
    updateOperationDisplay();
}

function toggleSign() {
    if (currentNumber !== '0') {
        currentNumber = (parseFloat(currentNumber) * -1).toString();
        updateDisplay();
    }
}
</script>
